---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import EmailSignup from "../../components/EmailSignup.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<BaseLayout
  title="Gift guides"
  description="Our short list of guides for the men in your life. Every item is something we'd give to our own dads."
>
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-10 sm:pt-24">
    <p class="text-xs uppercase tracking-[0.2em] text-olive">Guides</p>
    <h1 class="mt-3 font-serif text-4xl text-ink sm:text-5xl">
      The short list.
    </h1>
    <p class="mt-4 max-w-2xl text-muted">
      A small number of guides, written like a friend would recommend them.
      Every item is something we'd give to our own dads — practical,
      hard-wearing, and worth the price.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {guides.map((g) => (
        <Card
          variant="guide"
          href={`/guides/${g.slug}`}
          title={g.data.title}
          description={g.data.description}
          image={g.data.heroImage}
          imageAlt={g.data.heroAlt}
          eyebrow={g.data.publishDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
          })}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <EmailSignup />
  </section>
</BaseLayout>
