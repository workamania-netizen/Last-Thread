---
export const prerender = true;

import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import EmailSignup from "../../components/EmailSignup.astro";

export async function getStaticPaths() {
  const entries = await getCollection("guides");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"guides">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, heroImage, heroAlt, publishDate, items } = entry.data;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
>
  <article>
    <header class="mx-auto max-w-3xl px-6 pt-16 pb-10 sm:pt-24">
      <p class="text-xs uppercase tracking-[0.2em] text-olive">
        Gift guide
        <span class="mx-2">·</span>
        {publishDate.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </p>
      <h1 class="mt-4 font-serif text-4xl leading-tight text-ink sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 text-lg text-muted">{description}</p>
    </header>

    <figure class="mx-auto max-w-4xl px-6">
      <Image
        src={heroImage}
        alt={heroAlt}
        widths={[600, 1200, 1800, 2400]}
        sizes="(min-width: 1024px) 56rem, 100vw"
        class="aspect-[16/9] w-full rounded-lg object-cover"
      />
    </figure>

    <section class="mx-auto max-w-3xl px-6 py-12">
      <div class="prose-lt space-y-5 text-ink/90">
        <Content />
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-6 pb-16">
      <ol class="space-y-10">
        {items.map((item, i) => (
          <li class="grid gap-6 md:grid-cols-[1fr_1.2fr] md:gap-10" id={item.slug}>
            <div class="overflow-hidden rounded-lg border border-tan bg-surface">
              <div class="aspect-[4/3] overflow-hidden bg-tan/40">
                <img
                  src={item.image}
                  alt={item.imageAlt ?? item.name}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
            </div>
            <div class="flex flex-col justify-center">
              <p class="text-xs uppercase tracking-widest text-olive">
                No. {String(i + 1).padStart(2, "0")}
              </p>
              <h2 class="mt-1 font-serif text-2xl text-ink sm:text-3xl">
                {item.name}
              </h2>
              <p class="mt-4 text-ink/90">{item.blurb}</p>
              <div class="mt-5 flex items-center gap-4">
                <a
                  href={`/go/${item.slug}`}
                  target="_blank"
                  rel="noopener sponsored"
                  data-outbound-slug={item.slug}
                  class="inline-flex items-center gap-1 rounded-md bg-accent px-4 py-2 text-sm font-medium text-cream hover:bg-accent-dark"
                >
                  Shop this
                  <span aria-hidden="true">&rarr;</span>
                </a>
                {item.priceRange && (
                  <span class="text-sm text-muted">{item.priceRange}</span>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mx-auto max-w-5xl px-6 pb-24">
      <EmailSignup />
    </section>
  </article>
</BaseLayout>

<style>
  .prose-lt p { font-size: 1.0625rem; line-height: 1.75; color: var(--color-ink); }
  .prose-lt h2 { font-family: var(--font-serif); font-size: 1.5rem; margin-top: 2rem; }
  .prose-lt a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
</style>

<script define:vars={{ title, slug: entry.slug }}>
  const w = window;
  if (w.fbq) w.fbq("track", "ViewContent", { content_name: title, content_category: "guide", content_ids: [slug] });
  if (w.gtag) w.gtag("event", "view_item", { item_name: title, item_category: "guide", item_id: slug });

  // Outbound click tracking — fbq/gtag use sendBeacon-style transports
  // internally, so the events survive the immediate navigation that follows.
  // Server-side log in /go/[slug].ts is the authoritative record.
  document.querySelectorAll("a[data-outbound-slug]").forEach((a) => {
    a.addEventListener("click", () => {
      const s = a.getAttribute("data-outbound-slug");
      if (!s) return;
      if (w.fbq) w.fbq("trackCustom", "OutboundClick", { slug: s, guide: slug });
      if (w.gtag) w.gtag("event", "outbound_click", { slug: s, guide: slug, transport_type: "beacon" });
    });
  });
</script>
