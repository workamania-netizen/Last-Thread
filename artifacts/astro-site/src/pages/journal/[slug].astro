---
export const prerender = true;

import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailSignup from "../../components/EmailSignup.astro";

export async function getStaticPaths() {
  const entries = await getCollection("journal");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"journal">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, heroImage, heroAlt, publishDate, author } = entry.data;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="mx-auto max-w-2xl px-6 pt-16 pb-12 sm:pt-24">
    <p class="text-xs uppercase tracking-[0.2em] text-olive">
      Journal
      <span class="mx-2">·</span>
      {publishDate.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </p>
    <h1 class="mt-4 font-serif text-4xl leading-tight text-ink sm:text-5xl">
      {title}
    </h1>
    <p class="mt-4 text-sm text-muted">By {author}</p>
  </article>

  <figure class="mx-auto max-w-4xl px-6 pb-12">
    <Image
      src={heroImage}
      alt={heroAlt}
      widths={[600, 1200, 1800]}
      sizes="(min-width: 1024px) 56rem, 100vw"
      class="aspect-[16/9] w-full rounded-lg object-cover"
    />
  </figure>

  <section class="mx-auto max-w-2xl px-6 pb-16">
    <div class="prose-lt space-y-5 text-ink/90">
      <Content />
    </div>
  </section>

  <section class="mx-auto max-w-2xl px-6 pb-24">
    <EmailSignup />
  </section>
</BaseLayout>

<style>
  .prose-lt p { font-size: 1.0625rem; line-height: 1.75; color: var(--color-ink); }
  .prose-lt h2 { font-family: var(--font-serif); font-size: 1.5rem; margin-top: 2rem; }
  .prose-lt a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose-lt blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-muted);
  }
</style>

<script define:vars={{ title, slug: entry.slug }}>
  const w = window;
  if (w.fbq) w.fbq("track", "ViewContent", { content_name: title, content_category: "journal", content_ids: [slug] });
  if (w.gtag) w.gtag("event", "view_item", { item_name: title, item_category: "journal", item_id: slug });
</script>
