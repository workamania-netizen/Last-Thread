---
export const prerender = true;

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailSignup from "../components/EmailSignup.astro";
import Card from "../components/Card.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const journal = (await getCollection("journal"))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
const featured = guides.find((g) => g.data.featured) ?? guides[0];
---

<BaseLayout
  title="Last Thread Co."
  description="Gifts for the men who wear things out. Editorial guides, no filler."
>
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-24">
    <p class="text-xs uppercase tracking-[0.2em] text-olive">
      For the men who wear things out
    </p>
    <h1 class="mt-4 font-serif text-4xl leading-tight text-ink sm:text-6xl">
      A short list of <span class="text-accent">good things</span> for the
      men in your life.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-muted">
      He's been carrying the same wallet since the second Bush administration.
      The hoodie is older than your nephew. We make gift guides for him —
      practical things, things that last, things he'll actually use.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/guides"
        class="rounded-md bg-accent px-5 py-3 font-medium text-cream hover:bg-accent-dark"
      >
        Browse the guides
      </a>
      <a
        href="/journal"
        class="rounded-md border border-tan px-5 py-3 font-medium text-ink hover:border-accent hover:text-accent"
      >
        Read the journal
      </a>
    </div>
  </section>

  {featured && (
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <a
        href={`/guides/${featured.slug}`}
        class="group grid overflow-hidden rounded-lg border border-tan bg-surface md:grid-cols-2"
      >
        <div class="aspect-[4/3] overflow-hidden bg-tan/40 md:aspect-auto">
          <Image
            src={featured.data.heroImage}
            alt={featured.data.heroAlt}
            widths={[600, 1200, 1800]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          />
        </div>
        <div class="p-8 sm:p-10">
          <p class="text-xs uppercase tracking-widest text-olive">
            The current guide
          </p>
          <h2 class="mt-2 font-serif text-3xl text-ink group-hover:text-accent">
            {featured.data.title}
          </h2>
          <p class="mt-4 text-muted">{featured.data.description}</p>
          <p class="mt-6 text-sm text-accent">Read the guide &rarr;</p>
        </div>
      </a>
    </section>
  )}

  <section class="mx-auto max-w-5xl px-6 pb-16">
    <div class="flex items-end justify-between">
      <h2 class="font-serif text-2xl text-ink sm:text-3xl">More guides</h2>
      <a href="/guides" class="text-sm text-accent hover:text-accent-dark">All guides &rarr;</a>
    </div>
    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      {guides
        .filter((g) => g.slug !== featured?.slug)
        .map((g) => (
          <Card
            variant="guide"
            href={`/guides/${g.slug}`}
            title={g.data.title}
            description={g.data.description}
            image={g.data.heroImage}
            imageAlt={g.data.heroAlt}
            eyebrow="Guide"
          />
        ))}
    </div>
  </section>

  {journal.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <div class="flex items-end justify-between">
        <h2 class="font-serif text-2xl text-ink sm:text-3xl">From the journal</h2>
        <a href="/journal" class="text-sm text-accent hover:text-accent-dark">
          All posts &rarr;
        </a>
      </div>
      <ul class="mt-6 divide-y divide-tan/60 border-y border-tan/60">
        {journal.map((post) => (
          <li>
            <a
              href={`/journal/${post.slug}`}
              class="group flex flex-col gap-1 py-5 sm:flex-row sm:items-baseline sm:justify-between"
            >
              <span class="font-serif text-lg text-ink group-hover:text-accent">
                {post.data.title}
              </span>
              <span class="text-sm text-muted">
                {post.data.publishDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <EmailSignup />
  </section>
</BaseLayout>
