---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import EmailSignup from "../components/EmailSignup.astro";
import {
  getSectionsInOrder,
  getProductsForSection,
  type Product,
  type Section,
} from "../data/products";

const sectionsInOrder = await getSectionsInOrder();

const populatedSections: { section: Section; products: Product[] }[] = [];
for (const section of sectionsInOrder) {
  const products = await getProductsForSection(section.id);
  if (products.length > 0) populatedSections.push({ section, products });
}

function formatPrice(price: number): string {
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: Number.isInteger(price) ? 0 : 2,
  }).format(price);
}

// Placeholder hero stills from the v2 mockup. At least one is off-brand
// (a volcano) — these get swapped for localized photography in a follow-up
// before paid traffic, per the founder. Don't reach for image fixes here.
const heroSlides = [
  "https://images.unsplash.com/photo-1517825738774-7de9363ef735?w=1800&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1452830978618-d6feae7d0ffa?w=1800&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1518457607834-6e8d80c183c5?w=1800&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1542293787938-c9e299b88010?w=1800&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1481833761820-0509d3217039?w=1800&q=85&auto=format&fit=crop",
];

const totalSlides = String(heroSlides.length).padStart(2, "0");
---

<BaseLayout
  title="Last Thread Co."
  description="Gifts for the men who wear things out. Editorial guides, no filler."
  heroOverlayHeader={true}
>
  <section
    class="hero relative w-full h-[80vh] min-h-[640px] overflow-hidden bg-ink"
    aria-roledescription="carousel"
    aria-label="Field reel"
    data-hero
  >
    {heroSlides.map((src, i) => (
      <div
        class:list={[
          "hero-slide absolute inset-0 bg-cover bg-center transition-opacity duration-[1600ms] ease-[cubic-bezier(.4,0,.2,1)]",
          i === 0 && "is-active",
        ]}
        style={`background-image: url('${src}')`}
        role="group"
        aria-roledescription="slide"
        aria-label={`${i + 1} of ${heroSlides.length}`}
        aria-hidden={i !== 0 ? "true" : "false"}
        data-slide
      />
    ))}

    <div
      class="absolute left-12 right-12 bottom-[42px] z-[5] flex items-end justify-between gap-8 text-surface"
    >
      <h1 class="font-serif font-medium text-5xl sm:text-6xl lg:text-[64px] leading-[1.02] tracking-[-0.015em] max-w-[760px] text-pretty text-surface">
        For the men who<br />wear things out.
      </h1>
      <a
        href="/guides/fathers-day-gifts"
        class="group inline-flex items-center gap-2.5 bg-surface text-ink px-[22px] py-[14px] text-[13px] font-medium tracking-[0.06em] uppercase no-underline rounded-[2px] whitespace-nowrap transition-colors hover:bg-white"
      >
        See the Father's day guide
        <span
          class="inline-block transition-transform duration-200 group-hover:translate-x-1"
          aria-hidden="true"
        >→</span>
      </a>
    </div>

    <div
      class="absolute bottom-[42px] left-1/2 -translate-x-1/2 z-[6] flex gap-2.5 items-center"
      data-dots
      aria-label="Slide controls"
    ></div>

    <div
      class="absolute right-12 top-[34px] z-[6] text-surface font-serif text-sm tracking-[0.04em] flex gap-1.5 items-baseline [text-shadow:0_1px_8px_rgba(0,0,0,.3)]"
    >
      <span class="text-[22px]" data-slide-cur>01</span>
      <span class="opacity-[0.55]">/ {totalSlides}</span>
    </div>
  </section>

  <section class="py-24 px-12 flex justify-center">
    <div class="max-w-[720px]">
      <div class="font-serif italic text-sm text-accent mb-[22px] tracking-[0.02em]">
        — On the record
      </div>
      <p class="font-serif font-medium text-3xl leading-[1.32] tracking-[-0.005em] text-ink text-pretty">
        He's been carrying the same wallet since the second Bush
        administration. The hoodie is older than your nephew. We make gift
        guides for him — practical things, things that last, things he'll
        actually use.
      </p>
    </div>
  </section>

  {populatedSections.length > 0 && (
    <div class="bg-cream border-t border-tan pt-10 pb-[120px]">
      {populatedSections.map(({ section, products }) => (
        <section
          class="mb-16 last:mb-0"
          data-rail-section
          aria-label={section.name || "Products"}
        >
          {section.name && (
            <div class="flex items-end justify-between px-12 mb-9">
              <h2 class="font-serif font-medium text-4xl tracking-[-0.01em] leading-none">
                {section.name}
              </h2>
              <div class="flex gap-2">
                <button
                  type="button"
                  class="w-[46px] h-[46px] border border-tan bg-transparent text-ink flex items-center justify-center rounded-full transition-colors hover:bg-surface hover:border-ink"
                  aria-label="Previous"
                  data-rail-prev
                >
                  <svg
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="w-4 h-4"
                    aria-hidden="true"
                  >
                    <path d="M10 3L5 8l5 5" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="w-[46px] h-[46px] border border-tan bg-transparent text-ink flex items-center justify-center rounded-full transition-colors hover:bg-surface hover:border-ink"
                  aria-label="Next"
                  data-rail-next
                >
                  <svg
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="w-4 h-4"
                    aria-hidden="true"
                  >
                    <path d="M6 3l5 5-5 5" />
                  </svg>
                </button>
              </div>
            </div>
          )}

          <div class="relative">
            <div
              class="rail flex gap-7 overflow-x-auto snap-x snap-mandatory px-12 pb-6"
              data-rail
            >
              {products.map((product) => (
                <a
                  href={`/products/${product.slug}`}
                  class="card group flex-none w-80 snap-start no-underline text-inherit block"
                >
                  <div class="aspect-[4/5] overflow-hidden bg-tan/40 mb-4">
                    {product.imageUrl && (
                      <img
                        src={product.imageUrl}
                        alt={product.name}
                        loading="lazy"
                        class="w-full h-full object-cover transition-transform duration-[400ms] ease-out group-hover:-translate-y-1"
                      />
                    )}
                  </div>
                  <h3 class="font-serif font-medium text-xl leading-[1.2] max-w-[280px] text-pretty">
                    {product.name}
                  </h3>
                  {product.price !== null && (
                    <div class="text-[13px] text-muted mt-1.5">
                      {formatPrice(product.price)}
                    </div>
                  )}
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  )}

  <section class="bg-surface py-24 px-12 border-t border-tan">
    <div class="max-w-[640px] mx-auto text-center">
      <div class="text-[11px] uppercase tracking-[0.22em] text-accent mb-[18px]">
        The newsletter
      </div>
      <div class="max-w-[440px] mx-auto text-center">
        <EmailSignup
          heading="It comes out when it has something to say."
          subhead="New gift guides, the occasional journal post, nothing else. No sales emails. No clever subject lines."
          variant="inline"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Two-stop legibility gradient. Top band is strengthened from the v2
     mockup spec (22%→0 over 18%) to 55%→0 over 22% so the surface-white
     overlay nav stays readable against any slide. Bottom band unchanged. */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(14, 13, 11, 0.55) 0%, rgba(14, 13, 11, 0) 22%),
      linear-gradient(0deg, rgba(14, 13, 11, 0.78) 0%, rgba(14, 13, 11, 0) 40%);
  }

  /* Slide state — opacity + ken-burns animation on active. Inactive
     slides stay scaled 1.02 to keep the zoom-in feel on first reveal. */
  .hero-slide {
    opacity: 0;
    transform: scale(1.02);
  }
  .hero-slide.is-active {
    opacity: 1;
    animation: kenburns 8s ease-out forwards;
  }
  @keyframes kenburns {
    from { transform: scale(1.02); }
    to   { transform: scale(1.08); }
  }

  /* Dot controls — created in JS, styled here. */
  .dot {
    width: 32px;
    height: 2px;
    background: rgba(251, 248, 242, 0.35);
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s, transform 0.25s;
  }
  .dot.is-active {
    background: var(--color-surface);
    transform: scaleY(2);
  }
  .dot:hover { background: rgba(251, 248, 242, 0.7); }

  /* Hide rail scrollbar — controls go through the arrow buttons. */
  .rail {
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .rail::-webkit-scrollbar { display: none; }

  /* Reduced-motion: kill ken-burns + shorten the cross-fade. The JS
     guard separately skips the auto-rotate timer. */
  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      transition: opacity 200ms linear;
    }
    .hero-slide.is-active {
      animation: none;
      transform: none;
    }
  }
</style>

<script>
  (function () {
    const reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const hero = document.querySelector<HTMLElement>("[data-hero]");
    if (hero) {
      const slides = Array.from(
        hero.querySelectorAll<HTMLElement>("[data-slide]"),
      );
      const dotsWrap = hero.querySelector<HTMLElement>("[data-dots]");
      const cur = hero.querySelector<HTMLElement>("[data-slide-cur]");

      if (slides.length && dotsWrap && cur) {
        let idx = 0;
        let timer: number | null = null;

        slides.forEach((_, i) => {
          const b = document.createElement("button");
          b.type = "button";
          b.className = "dot" + (i === 0 ? " is-active" : "");
          b.setAttribute("aria-label", "Show slide " + (i + 1));
          b.addEventListener("click", () => go(i, true));
          dotsWrap.appendChild(b);
        });
        const dots = Array.from(dotsWrap.children) as HTMLElement[];

        function go(n: number, manual: boolean) {
          slides[idx].classList.remove("is-active");
          slides[idx].setAttribute("aria-hidden", "true");
          dots[idx].classList.remove("is-active");
          idx = (n + slides.length) % slides.length;
          slides[idx].classList.add("is-active");
          slides[idx].setAttribute("aria-hidden", "false");
          dots[idx].classList.add("is-active");
          cur!.textContent = String(idx + 1).padStart(2, "0");
          if (manual && !reduce && timer !== null) {
            clearInterval(timer);
            start();
          }
        }
        function start() {
          timer = window.setInterval(() => go(idx + 1, false), 5000);
        }
        if (!reduce) start();
      }
    }

    // Scoped per section: prev/next buttons only exist when section.name
    // is non-empty, but the rail itself is always present. Looking them
    // up within the section avoids any cross-rail wiring.
    document
      .querySelectorAll<HTMLElement>("[data-rail-section]")
      .forEach((section) => {
        const rail = section.querySelector<HTMLElement>("[data-rail]");
        const prev = section.querySelector<HTMLElement>("[data-rail-prev]");
        const next = section.querySelector<HTMLElement>("[data-rail-next]");
        if (rail && prev && next) {
          prev.addEventListener("click", () =>
            rail.scrollBy({ left: -380, behavior: "smooth" }),
          );
          next.addEventListener("click", () =>
            rail.scrollBy({ left: 380, behavior: "smooth" }),
          );
        }
      });
  })();
</script>
