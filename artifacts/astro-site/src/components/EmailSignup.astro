---
interface Props {
  heading?: string;
  subhead?: string;
  variant?: "inline" | "card";
}

const {
  heading = "Get one good thing a week.",
  subhead = "A short list of the best things we've found, every Saturday. No filler.",
  variant = "card",
} = Astro.props;
---

<section
  class:list={[
    variant === "card" &&
      "rounded-lg border border-tan bg-surface p-8 sm:p-10",
  ]}
  data-email-signup
>
  <h2 class="font-serif text-2xl font-medium text-ink sm:text-3xl">
    {heading}
  </h2>
  <p class="mt-2 max-w-lg text-muted">{subhead}</p>

  <form
    class="mt-5 flex flex-col gap-3 sm:flex-row"
    data-form
    novalidate
  >
    <label class="sr-only" for="lt-email">Email address</label>
    <input
      id="lt-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="you@example.com"
      class="flex-1 rounded-md border border-tan bg-cream px-4 py-3 text-ink placeholder:text-muted/70 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
    />
    {/* Honeypot — bots will fill it; humans won't see it */}
    <input
      type="text"
      name="company"
      tabindex="-1"
      autocomplete="off"
      class="absolute left-[-9999px] h-0 w-0 opacity-0"
      aria-hidden="true"
    />
    <button
      type="submit"
      class="rounded-md bg-accent px-5 py-3 font-medium text-cream transition hover:bg-accent-dark disabled:opacity-60"
      data-submit
    >
      Subscribe
    </button>
  </form>
  <p
    class="mt-3 hidden text-sm text-olive"
    data-status="success"
    role="status"
    aria-live="polite"
  >
    Thanks — we'll be in touch.
  </p>
  <p
    class="mt-3 hidden text-sm text-accent-dark"
    data-status="error"
    role="status"
    aria-live="polite"
  >
    Something went wrong. Try again in a minute.
  </p>
</section>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-email-signup]")
    .forEach((root) => {
      const form = root.querySelector<HTMLFormElement>("[data-form]");
      const submit = root.querySelector<HTMLButtonElement>("[data-submit]");
      const successEl = root.querySelector<HTMLElement>('[data-status="success"]');
      const errorEl = root.querySelector<HTMLElement>('[data-status="error"]');
      if (!form || !submit || !successEl || !errorEl) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        successEl.classList.add("hidden");
        errorEl.classList.add("hidden");

        const data = new FormData(form);
        const email = String(data.get("email") ?? "").trim();
        const company = String(data.get("company") ?? "");
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          errorEl.textContent = "Please enter a valid email.";
          errorEl.classList.remove("hidden");
          return;
        }

        submit.disabled = true;
        try {
          const res = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, company }),
          });
          if (!res.ok) throw new Error("subscribe failed");
          form.reset();
          successEl.classList.remove("hidden");

          const w = window as unknown as {
            fbq?: (...args: unknown[]) => void;
            gtag?: (...args: unknown[]) => void;
          };
          w.fbq?.("track", "Lead");
          w.gtag?.("event", "generate_lead");
        } catch {
          errorEl.textContent = "Something went wrong. Try again in a minute.";
          errorEl.classList.remove("hidden");
        } finally {
          submit.disabled = false;
        }
      });
    });
</script>
