# Meta Pixel ID (from Meta Business). If absent, the Pixel snippet does not render.
PUBLIC_META_PIXEL_ID=

# GA4 Measurement ID (e.g. G-XXXXXXXXXX). If absent, the GA4 snippet does not render.
PUBLIC_GA4_ID=

# Full URL to SSD's /api/crm/intake endpoint. Required for /api/subscribe to forward leads.
SSD_INTAKE_URL=
